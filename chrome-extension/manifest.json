{
  "manifest_version": 3,
  "name": "Multi-Frame Trading Unlocker",
  "version": "1.0.0",
  "description": "Removes iframe-blocking headers from Kite, Sensibull and NiftyTrader so they load inside the Multi-Frame Trading dashboard.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.zerodha.com/*",
    "https://*.sensibull.com/*",
    "https://*.niftytrader.in/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "trading_unlocker",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
